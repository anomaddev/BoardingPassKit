{
  "name": "boarding-pass-kit",
  "version": "2.1.6",
  "description": "Parse IATA BCBP v8 boarding pass barcodes and QR codes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "boarding-pass",
    "bcbp",
    "iata",
    "barcode",
    "airline"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomaddev/BoardingPassKit.git",
    "directory": "packages/node"
  },
  "bugs": {
    "url": "https://github.com/anomaddev/BoardingPassKit/issues"
  },
  "homepage": "https://github.com/anomaddev/BoardingPassKit/tree/main/packages/node#readme",
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
